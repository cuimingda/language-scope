{
  "manifest_version": 3,
  "name": "Language Scope",
  "version": "0.1.0",
  "description": "Monitor text on chatgpt.com/c/* and mark matching word patterns.",
  "permissions": ["storage", "scripting", "tabs", "webNavigation", "windows"],
  "host_permissions": ["https://chatgpt.com/*"],
  "icons": {
    "128": "icons/icon-disabled.png"
  },
  "background": {
    "service_worker": "background/service.js"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/c/*"],
      "js": [
        "scripts/highlight-engine.js",
        "scripts/highlight-runtime.js",
        "scripts/patterns.js",
        "scripts/content.js"
      ],
      "css": ["styles/content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": "icons/icon-disabled.png",
    "default_title": "Language Scope",
    "default_popup": "popup/popup.html"
  },
  "options_page": "options/options.html"
}
